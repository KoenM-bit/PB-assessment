# Application environment: local | staging | production
# Full matrix: docs/configuration.md
APP_ENV=local

# Databricks (server-side only — never expose to frontend)
# Workspace URL from browser address bar (no trailing slash)
DATABRICKS_HOST=https://adb-XXXXXXXXXX.XX.azuredatabricks.net
# User Settings → Developer → Access tokens → Generate new token
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXX
# SQL → SQL Warehouses → your warehouse → Connection details → HTTP path (last segment)
DATABRICKS_SQL_WAREHOUSE_ID=xxxxxxxxxxxxxxxx
# Serving → endpoint name (create in Step 5 of docs/databricks-setup.md)
DATABRICKS_SERVING_ENDPOINT=house-price-serving
# Unity Catalog name (create with: make databricks-init-catalog)
DATABRICKS_CATALOG=house_price_staging
DATABRICKS_SCHEMA=gold

# Model alias: challenger (staging) | champion (production)
MODEL_ALIAS=challenger

# Production (separate catalog + endpoint — use: make bootstrap-production)
# DATABRICKS_CATALOG=house_price_prod
# DATABRICKS_SERVING_ENDPOINT=house-price-serving-prod
# MODEL_ALIAS=champion

# Monitoring
MIN_EVALUATION_SAMPLE_SIZE=30

# Protect write operations (actual sales)
DEMO_WRITE_TOKEN=change-me-in-production

# Serving
SERVING_TIMEOUT_MS=30000
SQL_MAX_WAIT_MS=25000

# Set to false once Databricks is configured (verify with: make verify-databricks)
USE_MOCK_DATABRICKS=true

# MLflow — experiments logged to Databricks when HOST + TOKEN are set (default for make train)
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc
MLFLOW_EXPERIMENT_NAME=/Shared/house_price_prediction
# Lab lane (notebook / ml_experiment_pipeline — no UC register):
# MLFLOW_EXPERIMENT_NAME=/Shared/house_price_prediction_lab
# make train = experiment + UC model version when run with --register (Makefile does this)
# Notebook explore: train(..., register_model=False)  — default, no UC version
# Pipeline job: train(..., register_model=True) in 04_train_model.py

# --- GitHub Actions secrets (repo Settings → Secrets — same values as above) ---
# Copy DATABRICKS_HOST, DATABRICKS_TOKEN, DATABRICKS_SQL_WAREHOUSE_ID into GitHub.
# See docs/enterprise-workflow.md
