# Copy these into Netlify → Site configuration → Environment variables
# Scope: set server-side vars for "Functions" (or "All scopes").
# Never expose DATABRICKS_TOKEN or DEMO_WRITE_TOKEN to the browser build.

# --- Required for real Databricks integration ---
APP_ENV=staging
USE_MOCK_DATABRICKS=false

DATABRICKS_HOST=https://dbc-XXXXXXXX.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXX
DATABRICKS_SQL_WAREHOUSE_ID=xxxxxxxxxxxxxxxx
DATABRICKS_SERVING_ENDPOINT=house-price-serving
DATABRICKS_CATALOG=house_price_staging
DATABRICKS_SCHEMA=gold

MODEL_ALIAS=challenger

# --- App behaviour ---
MIN_EVALUATION_SAMPLE_SIZE=30
SERVING_TIMEOUT_MS=30000
SQL_MAX_WAIT_MS=25000
DEMO_WRITE_TOKEN=choose-a-long-random-secret

# --- Set automatically by netlify.toml + config.ts per deploy context (free tier) ---
# You only need ONE set of Databricks secrets in the Netlify UI (host, token, warehouse).
# Branch `staging`  → house-price-serving + house_price_staging + challenger
# Branch `master`   → house-price-serving-prod + house_price_prod + champion
# PR previews       → same as staging
#
# Local overrides below are optional; deployed routing ignores them when APP_ENV is staging/production.
